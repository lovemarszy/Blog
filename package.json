{
  "name": "Marszy's blog",
  "author": "Marszy",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "node ./scripts/gen-rss.mjs && next build && next-sitemap --config ./scripts/next-sitemap.config.js",
    "start": "next start",
    "lint": "next lint",
    "prepare": "husky"
  },
  "dependencies": {
    "@giscus/react": "^3.1.0",
    "autoprefixer": "^10.4.23",
    "gray-matter": "^4.0.3",
    "next": "^14.2.35",
    "next-sitemap": "^4.2.3",
    "nextra": "2.13.4",
    "nextra-theme-blog": "2.13.4",
    "postcss": "^8.5.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-icons": "^5.6.0",
    "rss": "^1.2.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@next/env": "^16.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "marked": "^17.0.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,jsx,ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,css,md,mdx}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "cross-spawn": ">=7.0.6",
      "minimatch": ">=10.2.5",
      "@typescript-eslint/typescript-estree>minimatch": ">=10.2.5",
      "flatted": ">=3.4.2",
      "picomatch": ">=2.3.2 <3.0.0 || >=4.0.4",
      "tinyglobby>picomatch": ">=4.0.4",
      "@next/eslint-plugin-next>picomatch": ">=4.0.4",
      "lodash-es": ">=4.18.1",
      "dompurify": ">=3.4.0",
      "brace-expansion": ">=5.0.5",
      "yaml": ">=2.8.3",
      "diff": ">=8.0.4",
      "next-mdx-remote": ">=6.0.0"
    }
  }
}
